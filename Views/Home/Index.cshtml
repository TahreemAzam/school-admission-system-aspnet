@{
    ViewBag.Title = "Home - Morning Star High School";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<!-- Hero Slider -->
<div id="schoolCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/images/slider1.jpg" class="d-block w-100" alt="School Building">
            <div class="carousel-caption d-none d-md-block">
                <h2>Welcome to Our School</h2>
                <p>Empowering young minds through education and discipline.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/images/slider2.jpg" class="d-block w-100" alt="Students Learning">
            <div class="carousel-caption d-none d-md-block">
                <h2>Modern Classrooms</h2>
                <p>Learning made fun with technology and innovation.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/images/slider3.jpg" class="d-block w-100" alt="Sports">
            <div class="carousel-caption d-none d-md-block">
                <h2>Sports and Activities</h2>
                <p>Developing confidence, teamwork, and leadership.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/images/slider4.jpg" class="d-block w-100" alt="Library">
            <div class="carousel-caption d-none d-md-block">
                <h2>Dedicated Faculty</h2>
                <p>Guiding students towards excellence and character building.</p>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#schoolCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#schoolCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<!-- Welcome Section -->
<section class="py-5 text-center bg-light reveal">
    <div class="container">
        <h2 class="fw-bold mb-3">Welcome to Our School</h2>
        <p class="lead">We believe in quality education with strong moral values. Our mission is to nurture bright, responsible, and creative minds for a better future.</p>
    </div>
</section>

<!-- About & Mission Section -->
<section id="about" class="py-5 reveal">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6 mb-4 mb-md-0">
                <img src="~/images/school_about.jpg" alt="About School" class="img-fluid rounded shadow-sm">
            </div>
            <div class="col-md-6">
                <h3 class="fw-bold mb-3">About Our School</h3>
                <p>Our school provides a dynamic learning environment with modern teaching methods, co-curricular activities, and personalized attention to every student.</p>
                <h5 class="mt-4">Our Mission</h5>
                <p>To provide holistic education that inspires intellectual curiosity, moral integrity, and lifelong learning habits.</p>
            </div>
        </div>
    </div>
</section>

<!-- Principal's Message -->
<section class="py-5 bg-light reveal">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Principal’s Message</h2>
        </div>
        <div class="row justify-content-center align-items-center">
            <div class="col-md-3 text-center mb-4 mb-md-0">
                <img src="~/images/principal.jpg" alt="Principal" class="rounded-circle shadow-sm" width="160" height="160">
                <h5 class="mt-3">Sir Hassan Javed</h5>
                <p class="text-muted mb-0">Principal</p>
            </div>
            <div class="col-md-7">
                <blockquote class="blockquote">
                    <p class="mb-3">“Education is the most powerful weapon which you can use to change the world. Our aim is to build responsible, confident, and creative individuals ready to face the challenges of tomorrow.”</p>
                    <footer class="blockquote-footer">Sir Hassan Javed, Principal</footer>
                </blockquote>
            </div>
        </div>
    </div>
</section>
