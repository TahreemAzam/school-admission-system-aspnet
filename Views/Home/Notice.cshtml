@{
}
@{
    ViewBag.Title = "Notice - Morning Star High School";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="notice-section py-5">
    <div class="container">
        <h2 class="section-title text-center mb-5">Notices & Announcements</h2>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="notice-card shadow-sm p-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong class="notice-title">Exam Schedule Released</strong>
                        <span class="notice-date">Oct 20, 2025</span>
                    </div>
                    <p>Midterm exam schedules are now available. Please check the notice board for details.</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="notice-card shadow-sm p-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong class="notice-title">Parent-Teacher Meeting</strong>
                        <span class="notice-date">Nov 12, 2025</span>
                    </div>
                    <p>All parents are requested to attend between 9:00 AM and 2:00 PM.</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="notice-card shadow-sm p-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong class="notice-title">Sports Day</strong>
                        <span class="notice-date">Dec 05, 2025</span>
                    </div>
                    <p>Annual sports day will be held on the school ground. Students must be in proper uniform.</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="notice-card shadow-sm p-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong class="notice-title">School Closed</strong>
                        <span class="notice-date">Dec 25, 2025</span>
                    </div>
                    <p>The school will remain closed on account of the winter break.</p>
                </div>
            </div>
        </div>
    </div>
</section>
