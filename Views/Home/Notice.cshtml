@{
    ViewBag.Title = "Notice - Morning Star High School";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model IEnumerable<SchoolWebsite1.Models.Notice>
<section class="notice-section py-5">
    <div class="container">
        <h2 class="section-title text-center mb-5" style="color:green; font-weight:600; letter-spacing:1px;">Notices & Announcements</h2>

        <div class="row g-4" id="noticeContainer">
            @* Loop through Model notices and render partial view for each *@
            @if (Model != null)
            {
                foreach (var notice in Model)
                {
                    <div class="col-md-6">
                        @await Html.PartialAsync("_NoticeInfo", notice)
                    </div>
                }
            }
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.7/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/noticeHub") // The URL of your SignalR hub
            .build();

        connection.on("ReceiveNotice", function (title, message, createdAt) {
            const container = document.getElementById("noticeContainer");

            const div = document.createElement("div");
            div.classList.add("col-md-6");

            div.innerHTML = `
                <div class="notice-card shadow-sm p-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong class="notice-title">${title}</strong>
                        <span class="notice-date">${new Date(createdAt).toLocaleDateString()}</span>
                    </div>
                    <p>${message}</p>
                </div>
            `;

            container.prepend(div); // Add new notice at the top
        });

        connection.start().catch(err => console.error(err.toString()));
    </script>
}




